# --- Django ---
DJANGO_SETTINGS_MODULE=tchokos.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=true

# Origines autorisées (frontend Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Brevo (emails transactionnels) ---
BREVO_API_KEY=
BREVO_SENDER_NAME=Tchokos
BREVO_SENDER_EMAIL=no-reply@tchokos.cm

# --- Tara Money (paiement Mobile Money — phase 2) ---
TARA_API_KEY=
TARA_MERCHANT_ID=

# --- OpenRouter (chatbot) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
