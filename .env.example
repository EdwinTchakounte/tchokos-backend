# --- Django ---
DJANGO_SETTINGS_MODULE=tchokos.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=true

# Origines autorisées (frontend Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Brevo (emails transactionnels) ---
BREVO_API_KEY=
BREVO_SENDER_NAME=Tchokos
BREVO_SENDER_EMAIL=no-reply@tchokos-sarl.com

# --- Tara Money (paiement Mobile Money MTN / Orange Cameroun) ---
TARA_API_KEY=
TARA_MERCHANT_ID=
# Tara ne signe pas ses webhooks : ce secret reste inutilisé (sécurité = HTTPS
# + URL secrète + vérif merchantId). Laisser vide.
TARA_WEBHOOK_SECRET=
# Base publique HTTPS du backend — URL de webhook envoyée à Tara
# ({PUBLIC_BASE_URL}/api/payments/webhook/tara/). En prod : https://api.tchokos-sarl.com
PUBLIC_BASE_URL=http://localhost:8010
# Modes recette — À LAISSER FALSE EN PROD (valident sans Tara / sans montant).
PAYMENTS_TEST_AUTO_VALIDATE=false
PAYMENTS_TEST_ALLOW_ANY_AMOUNT=false

# --- OpenRouter (chatbot) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
